# ─── Falantir v2 Environment Variables ─────────────────────
# Copy this to .env and fill in your values.
# NEVER commit the .env file to git.

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
# Database name is hardcoded as "falantir" in database_v2.py

# ─── Flask ────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_DEBUG=false
CORS_ORIGINS=http://localhost:5173

# ─── Gemini API ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Custom Threat Classifier ─────────────────────────────
MODEL_PATH=models/threat_classifier.pt
HUGGINGFACE_MODEL_REPO=your-username/falantir-threat-model
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ─── SMTP (Email Alerts) ─────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your_email@gmail.com

# ─── Twilio (SMS & Voice Alerts) ──────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
ALERT_TO_NUMBER=+1234567890

# ─── Detection Settings ──────────────────────────────────
MAX_CAMERAS=5
FRAME_SKIP=3
THREAT_THRESHOLD=0.6
